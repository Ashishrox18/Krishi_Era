# Server Configuration
PORT=3000
NODE_ENV=development

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# DynamoDB Tables
DYNAMODB_USERS_TABLE=krishi-users
DYNAMODB_CROPS_TABLE=krishi-crops
DYNAMODB_ORDERS_TABLE=krishi-orders
DYNAMODB_SHIPMENTS_TABLE=krishi-shipments
DYNAMODB_STORAGE_TABLE=krishi-storage
DYNAMODB_TRANSACTIONS_TABLE=krishi-transactions

# S3 Buckets
S3_IMAGES_BUCKET=krishi-images-1772218008
S3_DOCUMENTS_BUCKET=krishi-documents-1772218008

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# SNS Topics
SNS_NOTIFICATIONS_TOPIC_ARN=arn:aws:sns:us-east-1:120569622669:krishi-notifications

# IoT Configuration
IOT_ENDPOINT=yaypnvzs59kv17-ats.iot.us-east-1.amazonaws.com

# API Keys
WEATHER_API_KEY=your_weather_api_key

# AI Configuration
# Groq AI (Free, Cloud-based) - For crop recommendations
# Get your free API key from: https://console.groq.com/keys
# Sign up is free and takes 1 minute
USE_GROQ=true
GROQ_API_KEY=your_groq_api_key_here

# AI Configuration (Choose one)
# Option 1: Use Groq (Free, Cloud, Fast)
USE_GROQ=true
GROQ_API_KEY=your_groq_api_key_here

# Option 2: Use Ollama (Free, Local)
# USE_OLLAMA=true
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# Option 3: Use AWS Bedrock (Paid, Cloud)
# USE_OLLAMA=false
# (AWS credentials above will be used)
